# Application Metadata
APP_NAME=Luna Backend
APP_VERSION=0.1.0

# Server Network Configuration
HOST=127.0.0.1
PORT=8000

# Database Connection URL (SQLite is the default for local installations)
DATABASE_URL=sqlite:///./storage/luna.db

# AI & LLM Engine Settings
OLLAMA_HOST=http://localhost:11434
DEFAULT_MODEL=phi4-mini
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Environment Settings & Log Detail Levels (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
