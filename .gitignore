# ==========================================================
backend/.venv/
backend/venv/
backend/env/

__pycache__/
*.py[cod]
*.pyo

*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Python build
build/
dist/

# ==========================================================
