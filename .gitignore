# ==========================================================
frontend/node_modules/

frontend/dist/
frontend/dist-electron/
frontend/release/

frontend/.vite/

*.tgz

# ==========================================================
# Environment
# ==========================================================
.env
.env.*
!.env.example

# ==========================================================
# IDE
# ==========================================================
.vscode/
.idea/

*.suo
*.user

# ==========================================================
